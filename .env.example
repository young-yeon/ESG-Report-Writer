# OpenAI-compatible chat completions base URL.
# Include /v1 here. The frontend app appends /chat/completions automatically.
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:30000/v1

# Optional. Leave empty when the compatible server does not require auth.
OPENAI_COMPATIBLE_API_KEY=

# Initial model name shown in the app.
LLM_MODEL=Qwen3.6

# Thinking control sent with each LLM request.
# auto: disable thinking for Qwen3 model names, leave other models unchanged.
# disabled: send chat_template_kwargs.enable_thinking=false and append /no_think.
# soft: append /no_think only, useful if the server rejects chat_template_kwargs.
# server: do not send thinking controls.
# enabled: send chat_template_kwargs.enable_thinking=true and append /think.
LLM_THINKING_MODE=auto

# Maximum extracted attachment text sent to the first-stage LLM request.
# Lower this for smaller context windows, for example 60000 for 32k-class serving.
MAX_TOTAL_FILE_CHARS=180000

# Password required when opening the app.
APP_ACCESS_PASSWORD=admin

# Optional. Defaults to APP_ACCESS_PASSWORD when empty.
APP_SESSION_SECRET=
APP_SESSION_MAX_AGE_SECONDS=28800

# Static app server settings.
APP_HOST=127.0.0.1
APP_PORT=5173

# Server-side PDF export. Leave empty to auto-detect chromium/google-chrome.
PDF_CHROMIUM_PATH=
PDF_CHROMIUM_NO_SANDBOX=false
PDF_RENDER_TIMEOUT_MS=60000
PDF_MAX_HTML_BYTES=8388608
